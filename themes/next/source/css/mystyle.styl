// mystyle.styl，配置了一些个人风格的内容

/* 文字高亮
<span class="highlight">内容</span>
*/
.highlight {
  background-color: yellow;
  padding: 0 4px;
  border-radius: 2px;
}

/* 设置行间距 */
.post-body
  line-height: 1.6

/* 设置 tab 大小：通用 */
pre code
  tab-size: 4
  -moz-tab-size: 4
  -o-tab-size: 4

/* 设置 tab 大小：highlight.js 常见结构 */
.highlight pre,
.highlight code
  tab-size: 4
  -moz-tab-size: 4
  -o-tab-size: 4

/* 设置 tab 大小：PrismJS 常见结构（如果启用 Prism） */
pre[class*="language-"],
code[class*="language-"]
  tab-size: 4
  -moz-tab-size: 4
  -o-tab-size: 4

/* 引入 Maple Mono 字体 */ 
@font-face {
  font-family: 'Maple Mono';
  src: url('/fonts/MapleMono/MapleMono-NF-CN-Regular.ttf') format('truetype');
  font-weight: normal;
  font-style: normal;
  unicode-range: U+0020-007E;
}

@font-face {
  font-family: 'Maple Mono';
  src: url('/fonts/MapleMono/MapleMono-NF-CN-Bold.ttf') format('truetype');
  font-weight: bold;
  font-style: normal;
  unicode-range: U+0020-007E;
}